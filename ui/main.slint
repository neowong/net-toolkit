import { Button, LineEdit, TextEdit, ProgressIndicator, ListView } from "std-widgets.slint";

// ─────────────────────────────────────────────
//  数据结构
// ─────────────────────────────────────────────

export struct SubnetResult { label: string, value: string, }
export struct ScanResult   { ip: string, alive: bool, latency: string, }
export struct HttpResult   { url: string, status-code: string, latency: string, category: int, }

// ─────────────────────────────────────────────
//  通用小组件
// ─────────────────────────────────────────────

component NavItem inherits Rectangle {
    in property <string> label;
    in property <bool>   active;
    callback clicked;

    height: 52px;
    background: active ? #3498db : transparent;
    animate background { duration: 150ms; }

    TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 24px;
        alignment: start;
        Text {
            text: label;
            color: white;
            font-size: 14px;
            font-weight: active ? 700 : 400;
            vertical-alignment: center;
        }
    }
}

component Card inherits Rectangle {
    background: white;
    border-radius: 8px;
    drop-shadow-offset-x: 0px;
    drop-shadow-offset-y: 2px;
    drop-shadow-blur: 8px;
    drop-shadow-color: #00000018;
}

component FieldLabel inherits Text {
    font-size: 12px;
    color: #7f8c8d;
}

component ErrorBar inherits Rectangle {
    in property <string> message;
    height: 42px;
    background: #fdecea;
    border-radius: 6px;
    Text {
        x: 14px;
        y: 0;
        width: parent.width - 28px;
        height: parent.height;
        text: message;
        color: #c0392b;
        font-size: 13px;
        wrap: word-wrap;
        vertical-alignment: center;
    }
}

// 前缀长度微调器：▲/▼ 调节 + 可直接手动输入
component PrefixSpinBox inherits HorizontalLayout {
    // 父组件读取此值传给计算逻辑
    out property <string> val: "24";
    // 内部计数器，用于 ▲/▼ 运算
    property <int> num: 24;

    spacing: 0px;

    pe := LineEdit {
        width: 150px;
        text: "24";
        placeholder-text: "24 或 255.255.255.0";
        edited(v) => { val = v; }
    }

    Rectangle { width: 4px; background: transparent; }

    VerticalLayout {
        spacing: 2px;
        width: 28px;

        // ▲
        Rectangle {
            height: 19px;
            border-radius: 4px;
            background: up-ta.has-hover ? #bdc3c7 : #dde0e3;
            up-ta := TouchArea {
                clicked => {
                    if (num < 32) { num = num + 1; }
                    pe.text = "\{num}";
                    val   = "\{num}";
                }
            }
            Text { text: "▲"; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; color: #444; }
        }

        // ▼
        Rectangle {
            height: 19px;
            border-radius: 4px;
            background: dn-ta.has-hover ? #bdc3c7 : #dde0e3;
            dn-ta := TouchArea {
                clicked => {
                    if (num > 0) { num = num - 1; }
                    pe.text = "\{num}";
                    val   = "\{num}";
                }
            }
            Text { text: "▼"; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; color: #444; }
        }
    }
}

// ─────────────────────────────────────────────
//  子网计算页
// ─────────────────────────────────────────────

component SubnetPage inherits Rectangle {
    background: transparent;

    in property <[SubnetResult]> results: [];
    in property <string>         error: "";
    callback calculate-subnet(string, string);

    property <string> ip-val: "";

    VerticalLayout {
        padding: 30px;
        spacing: 16px;
        alignment: start;

        Text { text: "子网掩码计算器"; font-size: 20px; font-weight: 700; color: #2c3e50; }

        // 输入卡片（高度自适应内容）
        Card {
            VerticalLayout {
                padding: 20px;
                spacing: 0px;
                alignment: start;

                HorizontalLayout {
                    spacing: 16px;
                    alignment: start;

                    VerticalLayout {
                        spacing: 4px;
                        FieldLabel { text: "IP 地址"; }
                        LineEdit {
                            width: 210px;
                            placeholder-text: "例如: 192.168.1.0";
                            edited(v) => { ip-val = v; }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        FieldLabel { text: "前缀 / 掩码"; }
                        pfx := PrefixSpinBox { }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        FieldLabel { text: " "; }
                        Button {
                            text: "计 算";
                            primary: true;
                            clicked => { calculate-subnet(ip-val, pfx.val); }
                        }
                    }
                }
            }
        }

        if error != "" : ErrorBar { message: error; }

        if results.length > 0 : Card {
            VerticalLayout {
                padding: 20px;
                spacing: 8px;

                Text { text: "计算结果"; font-size: 15px; font-weight: 600; color: #34495e; }

                for item in results : Rectangle {
                    height: 34px;
                    background: #f8f9fa;
                    border-radius: 4px;
                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        Text { text: item.label; color: #7f8c8d; width: 170px; vertical-alignment: center; }
                        Text { text: item.value; color: #2c3e50; font-weight: 600; vertical-alignment: center; }
                    }
                }
            }
        }
    }
}

// ─────────────────────────────────────────────
//  IP 扫描页
// ─────────────────────────────────────────────

component ScannerPage inherits Rectangle {
    background: transparent;

    in property <[ScanResult]> results: [];
    in property <string>       status: "";
    in property <string>       scan-error: "";
    in-out property <bool>     scanning: false;
    in property <float>        progress: 0.0;

    callback start-scan(string, string, string);
    callback stop-scan();

    property <string> cidr-val: "";
    property <string> timeout-val: "1000";
    property <string> concurrent-val: "50";

    // 关键：去掉 alignment: start，让结果卡片能用 vertical-stretch 填满剩余空间
    VerticalLayout {
        padding: 30px;
        spacing: 16px;

        // 固定高度标题
        Text {
            text: "存活 IP 扫描";
            height: 28px;
            font-size: 20px;
            font-weight: 700;
            color: #2c3e50;
        }

        // 固定高度输入卡片
        Card {
            height: 110px;
            VerticalLayout {
                padding: 20px;
                spacing: 0px;
                alignment: start;

                HorizontalLayout {
                    spacing: 16px;
                    alignment: start;

                    VerticalLayout {
                        spacing: 4px;
                        FieldLabel { text: "网络地址 (CIDR)"; }
                        LineEdit {
                            width: 220px;
                            placeholder-text: "例如: 192.168.1.0/24";
                            edited(v) => { cidr-val = v; }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        FieldLabel { text: "超时 (毫秒)"; }
                        LineEdit {
                            width: 110px;
                            text: "1000";
                            edited(v) => { timeout-val = v; }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        FieldLabel { text: "并发数"; }
                        LineEdit {
                            width: 80px;
                            text: "50";
                            edited(v) => { concurrent-val = v; }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        FieldLabel { text: " "; }
                        Button {
                            text: scanning ? "停 止" : "开始扫描";
                            primary: !scanning;
                            clicked => {
                                if (scanning) {
                                    stop-scan();
                                } else {
                                    start-scan(cidr-val, timeout-val, concurrent-val);
                                }
                            }
                        }
                    }
                }
            }
        }

        // 错误（固定高度，有则显示）
        if scan-error != "" : ErrorBar { message: scan-error; }

        // 进度（固定高度）
        if scanning || progress > 0.0 : Card {
            height: 68px;
            VerticalLayout {
                padding: 14px;
                spacing: 8px;
                HorizontalLayout {
                    Text { text: "扫描进度"; font-size: 13px; color: #7f8c8d; horizontal-stretch: 1; vertical-alignment: center; }
                    Text { text: status;    font-size: 13px; color: #3498db; font-weight: 600;        vertical-alignment: center; }
                }
                ProgressIndicator { progress: progress; }
            }
        }

        // 结果卡片：vertical-stretch: 1 → 填满页面剩余高度
        if results.length > 0 : Card {
            vertical-stretch: 1;
            VerticalLayout {
                padding: 20px;
                spacing: 10px;

                HorizontalLayout {
                    Text { text: "存活主机"; font-size: 15px; font-weight: 600; color: #34495e; horizontal-stretch: 1; vertical-alignment: center; }
                    Text { text: "\{results.length} 台"; font-size: 14px; color: #27ae60; font-weight: 700; vertical-alignment: center; }
                }

                // 表头
                Rectangle {
                    height: 32px;
                    background: #ecf0f1;
                    border-radius: 4px;
                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        Text { text: "IP 地址"; font-weight: 700; color: #555; font-size: 13px; width: 200px; vertical-alignment: center; }
                        Text { text: "状态";   font-weight: 700; color: #555; font-size: 13px; width: 80px;  vertical-alignment: center; }
                        Text { text: "延迟";   font-weight: 700; color: #555; font-size: 13px;              vertical-alignment: center; }
                    }
                }

                // ListView 同样需要 vertical-stretch: 1，才能在 Card 内撑满
                ListView {
                    vertical-stretch: 1;
                    for item in results : Rectangle {
                        height: 32px;
                        background: transparent;
                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            Text { text: item.ip; color: #2c3e50; font-size: 13px; width: 200px; vertical-alignment: center; }
                            Text {
                                text: item.alive ? "存活" : "超时";
                                color: item.alive ? #27ae60 : #e74c3c;
                                font-weight: 600;
                                font-size: 13px;
                                width: 80px;
                                vertical-alignment: center;
                            }
                            Text { text: item.latency; color: #7f8c8d; font-size: 13px; vertical-alignment: center; }
                        }
                    }
                }
            }
        }
    }
}

// ─────────────────────────────────────────────
//  HTTP 检测页
// ─────────────────────────────────────────────

component HttpCheckPage inherits Rectangle {
    background: transparent;

    in property <[HttpResult]> results: [];
    in property <string>       http-status: "";
    in-out property <bool>     checking: false;

    callback start-check(string);

    property <string> urls-val: "";

    VerticalLayout {
        padding: 30px;
        spacing: 16px;

        Text {
            text: "HTTP 状态检测";
            height: 28px;
            font-size: 20px;
            font-weight: 700;
            color: #2c3e50;
        }

        Card {
            height: 160px;
            VerticalLayout {
                padding: 20px;
                spacing: 10px;
                FieldLabel { text: "输入 URL（每行一个）"; }
                TextEdit {
                    vertical-stretch: 1;
                    placeholder-text: "https://example.com\nhttps://google.com";
                    edited(v) => { urls-val = v; }
                }
                HorizontalLayout {
                    alignment: end;
                    Button {
                        text: checking ? "检测中..." : "开始检测";
                        primary: true;
                        enabled: !checking;
                        clicked => { start-check(urls-val); }
                    }
                }
            }
        }

        if http-status != "" : Text {
            text: http-status;
            color: #3498db;
            font-size: 13px;
        }

        if results.length > 0 : Card {
            vertical-stretch: 1;
            VerticalLayout {
                padding: 20px;
                spacing: 10px;

                Text { text: "检测结果"; font-size: 15px; font-weight: 600; color: #34495e; }

                Rectangle {
                    height: 32px;
                    background: #ecf0f1;
                    border-radius: 4px;
                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        Text { text: "URL";   font-weight: 700; color: #555; font-size: 13px; horizontal-stretch: 1; vertical-alignment: center; }
                        Text { text: "状态码"; font-weight: 700; color: #555; font-size: 13px; width: 120px;          vertical-alignment: center; }
                        Text { text: "延迟";  font-weight: 700; color: #555; font-size: 13px; width: 90px;           vertical-alignment: center; }
                    }
                }

                ListView {
                    vertical-stretch: 1;
                    for item in results : Rectangle {
                        height: 34px;
                        background: transparent;

                        property <color> sc:
                            item.category == 1 ? #27ae60 :
                            item.category == 2 ? #3498db :
                            item.category == 3 ? #e67e22 :
                            item.category == 4 ? #e74c3c : #95a5a6;

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            Text { text: item.url;         color: #2c3e50; font-size: 13px; horizontal-stretch: 1; vertical-alignment: center; overflow: elide; }
                            Text { text: item.status-code; color: sc;      font-size: 13px; font-weight: 700; width: 120px; vertical-alignment: center; }
                            Text { text: item.latency;     color: #7f8c8d; font-size: 13px; width: 90px;  vertical-alignment: center; }
                        }
                    }
                }
            }
        }
    }
}

// ─────────────────────────────────────────────
//  主窗口
// ─────────────────────────────────────────────

export component AppWindow inherits Window {
    title: "网络工程师工具箱";
    // 直接设置初始尺寸（preferred-* 在某些后端只是建议值，会被最小内容高度覆盖）
    width: 1100px;
    height: 720px;
    default-font-size: 14px;
    // 不指定 default-font-family，由系统 fontconfig 自动选含 CJK 的字体

    in-out property <int>           active-page: 0;

    callback calculate-subnet(string, string);
    in-out property <[SubnetResult]> subnet-results: [];
    in-out property <string>         subnet-error: "";

    callback start-scan(string, string, string);
    callback stop-scan();
    in-out property <bool>          scanning: false;
    in-out property <float>         scan-progress: 0.0;
    in-out property <[ScanResult]>  scan-results: [];
    in-out property <string>        scan-status: "";
    in-out property <string>        scan-error: "";

    callback start-http-check(string);
    in-out property <bool>          http-checking: false;
    in-out property <[HttpResult]>  http-results: [];
    in-out property <string>        http-status: "";

    HorizontalLayout {
        spacing: 0px;

        // ── 侧边栏 ──
        Rectangle {
            width: 160px;
            background: #2c3e50;

            VerticalLayout {
                padding: 0px;
                spacing: 0px;

                Rectangle {
                    height: 64px;
                    background: #1a252f;
                    Text {
                        text: "网络工具箱";
                        color: white;
                        font-size: 16px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle { height: 12px; background: transparent; }

                NavItem { label: "子网计算"; active: active-page == 0; clicked => { active-page = 0; } }
                NavItem { label: "IP 扫描";  active: active-page == 1; clicked => { active-page = 1; } }
                NavItem { label: "HTTP 检测"; active: active-page == 2; clicked => { active-page = 2; } }

                Rectangle { vertical-stretch: 1; background: transparent; }

                Rectangle {
                    height: 36px;
                    background: transparent;
                    Text { text: "v0.1.0"; color: #5d6d7e; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }

        // ── 内容区（三页用 visible 切换，保留各页状态）──
        Rectangle {
            horizontal-stretch: 1;
            background: #f0f3f7;

            SubnetPage {
                visible: active-page == 0;
                width: 100%; height: 100%;
                results: root.subnet-results;
                error:   root.subnet-error;
                calculate-subnet(ip, pfx) => { root.calculate-subnet(ip, pfx); }
            }

            ScannerPage {
                visible: active-page == 1;
                width: 100%; height: 100%;
                results:    root.scan-results;
                status:     root.scan-status;
                scan-error: root.scan-error;
                scanning  <=> root.scanning;
                progress:   root.scan-progress;
                start-scan(cidr, t, c) => { root.start-scan(cidr, t, c); }
                stop-scan => { root.stop-scan(); }
            }

            HttpCheckPage {
                visible: active-page == 2;
                width: 100%; height: 100%;
                results:     root.http-results;
                http-status: root.http-status;
                checking  <=> root.http-checking;
                start-check(urls) => { root.start-http-check(urls); }
            }
        }
    }
}
