{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "net-toolkit",
  "version": "0.1.0",
  "identifier": "com.net-toolkit.app",
  "build": {
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "网络工程师工具箱",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 580,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
