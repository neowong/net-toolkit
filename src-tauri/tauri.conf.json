{
  "productName": "AI-Inspection",
  "version": "3.58.0",
  "identifier": "com.inspection.rust",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "AI巡检助手",
        "width": 1500,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "visible": true,
        "decorations": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "deb",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "WebView2Loader.dll",
      "MicrosoftEdgeWebview2Setup.exe"
    ]
  }
}
